{
  "manifest_version": 3,
  "name": "Clicksmith",
  "description": "MCP server enabling Claude to test web apps in your real Chrome browser",
  "version": "0.1.0",
  "permissions": [
    "debugger",
    "activeTab",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {}
}
